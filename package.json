{
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "clean:node_modules": "find . -name node_modules -type d -prune -print -exec rm -rf '{}' +",
    "changeset:version": "npx changeset version",
    "changeset:publish": "npx changeset publish",
    "cs": "npx changeset",
    "catalog:bump": "node scripts/bump-catalog.mjs",
    "examples:bump": "node scripts/bump-examples.mjs",
    "bump": "pnpm run catalog:bump && pnpm examples:bump && pnpm i"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.9.3",
    "turbo": "^2.8.15"
  }
}
